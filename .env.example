# Server Configuration
NODE_ENV=development
PORT=9001
SESSION_SECRET=your-session-secret-here
BASE_URL=http://localhost:9001

# Database Configuration
SQL_HOST=localhost
SQL_PORT=3306
SQL_USER=your-db-user
SQL_PASS=your-db-password
SQL_DB=your-db-name
SQL_CONNECTION_LIMIT=20
SQL_CONNECT_TIMEOUT=30000
# Set to "true" to enable SSL for the database connection
SQL_SSL=false
SQL_SSL_REJECT_UNAUTHORIZED=true

# Edition Configuration
EDITION=1

# SMTP / Mailer Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=bolao@example.com

# Match Sync Service Configuration
# Enable/disable the automatic match sync service (default: true)
MATCH_SYNC_ENABLED=true

# Sync interval in milliseconds (default: 30000 = 30 seconds)
MATCH_SYNC_INTERVAL=30000

# External API Configuration
# Base URL for the external match data API
EXTERNAL_API_URL=https://api.example.com
