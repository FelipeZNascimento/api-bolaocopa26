# Server Configuration
NODE_ENV=development
PORT=9001
SESSION_SECRET=your-session-secret-here

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# Edition Configuration
EDITION=1

# Match Sync Service Configuration
# Enable/disable the automatic match sync service (default: true)
MATCH_SYNC_ENABLED=true

# Sync interval in milliseconds (default: 30000 = 30 seconds)
MATCH_SYNC_INTERVAL=30000

# External API Configuration
# Base URL for the external match data API
EXTERNAL_API_URL=https://api.example.com

# Optional: API key for external API authentication
EXTERNAL_API_KEY=your-api-key-here
